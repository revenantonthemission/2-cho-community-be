SECRET_KEY="your-secret-key-here"
# DEBUG: 상세 에러 메시지 노출 여부 (프로덕션에서는 반드시 false)
DEBUG=true
# HTTPS_ONLY: Controls whether cookies are sent only over HTTPS
# - False: Cookies work over HTTP (local dev, testing)
# - True: Cookies only over HTTPS (production with SSL)
HTTPS_ONLY=false

# MySQL Database Settings
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_USER="user_name_here"
DB_PASSWORD="secure_password_here"
DB_NAME="community_service"

# 이메일 발송 설정
EMAIL_BACKEND=smtp                    # ses (프로덕션) | smtp (로컬)
EMAIL_FROM=noreply@my-community.shop
SMTP_HOST=localhost
SMTP_PORT=1025                        # MailHog 로컬 개발용 (docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog)
SMTP_USER=
SMTP_PASSWORD=
SES_REGION=ap-northeast-2

# Rate Limiter 백엔드 (memory: 로컬 개발, redis: K8s 프로덕션)
RATE_LIMIT_BACKEND=memory

# 내부 API 인증 키 (EventBridge 배치 작업 호출에 사용)
# INTERNAL_API_KEY=                     # 프로덕션에서는 SSM으로 관리
